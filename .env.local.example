# Copy this file to .env.local and fill in your values.
# .env.local is gitignored - this example file is safe to commit.
#
# For GitHub Pages deployment via GitHub Actions, add each variable as a
# repository secret (Settings → Secrets and variables → Actions → New secret)
# then reference it in .github/workflows/deploy.yml under the build step env block.

# Admin portal PIN - gates access to /admin
NEXT_PUBLIC_ADMIN_PIN=changeme

# EmailJS - serverless contact form
# https://emailjs.com → Email Services (Service ID), Email Templates (Template ID), Account → API Keys (Public Key)
# Tip: also set Allowed Origins in EmailJS dashboard to restrict to your domain only
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# GitHub Contents API - enables live project CRUD from admin portal (no manual push)
# Create a Fine-grained PAT at github.com/settings/tokens with Contents: Read and Write on this repo only
# Without this token the admin portal falls back to snippet-copy mode (yellow warning shown)
NEXT_PUBLIC_GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
# Optional: override repo owner/name if forking or renaming
# NEXT_PUBLIC_GITHUB_OWNER=mattgraham93
# NEXT_PUBLIC_GITHUB_REPO=mattgraham93.github.io
